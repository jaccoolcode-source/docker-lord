# Docker Desktop TCP endpoint (enable in Docker Desktop Settings > General)
DOCKER_TCP_HOST=host.docker.internal
DOCKER_TCP_PORT=2375

# PostgreSQL credentials
POSTGRES_DB=docker-lord
POSTGRES_USER=docker-lord
POSTGRES_PASSWORD=change-me

# Host filesystem browsing (for folder picker)
HOST_PROJECTS_PATH=C:/Users/your-user/Documents/Projects
CONTAINER_PROJECTS_PATH=/host-projects
